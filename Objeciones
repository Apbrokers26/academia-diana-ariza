// ========== STATE ==========
let currentMode = 'search';
let gameQuestions = [];
let gameIndex = 0;
let gameScore = 0;
let answered = false;

// ========== MODE SWITCH ==========
function setMode(mode) {
  currentMode = mode;
  document.querySelectorAll('.mode-btn').forEach((b, i) => {
    b.classList.toggle('active', ['search','game','ref'][i] === mode);
  });
  document.getElementById('searchSection').classList.toggle('active', mode === 'search');
  document.getElementById('gameSection').classList.toggle('active', mode === 'game');
  document.getElementById('refSection').classList.toggle('active', mode === 'ref');

  if (mode === 'game') startGame();
  if (mode === 'ref') buildRef();
}

// ========== SEARCH ==========
function quickSearch(q) {
  document.getElementById('searchInput').value = q;
  handleSearch();
}

function handleSearch() {
  const query = document.getElementById('searchInput').value.toLowerCase().trim();
  const container = document.getElementById('searchResults');
  const noResult = document.getElementById('noResult');
  container.innerHTML = '';
  noResult.classList.remove('visible');

  if (!query || query.length < 2) return;

  const matches = OBJECTIONS.filter(obj => {
    return obj.keywords.some(k => k.includes(query) || query.includes(k)) ||
           obj.title.toLowerCase().includes(query) ||
           obj.meaning.toLowerCase().includes(query);
  });

  if (matches.length === 0) {
    noResult.classList.add('visible');
    return;
  }

  matches.forEach(obj => {
    const card = document.createElement('div');
    card.className = 'result-card visible';
    card.innerHTML = `
      <div class="objection-label">⚡ Objeción #${obj.id}</div>
      <div class="objection-title">${obj.title}</div>
      <div class="objection-subtext">Lo que realmente significa: "${obj.meaning}"</div>
      <div class="response-label">🎯 Tu Respuesta Ideal</div>
      <div class="response-text">${obj.response.replace(/\n\n/g,'<br><br>').replace(/\n/g,'<br>')}</div>
      <button class="copy-btn" onclick="copyText(this, \`${obj.response.replace(/`/g,'\\`')}\`)">📋 Copiar respuesta</button>
    `;
    container.appendChild(card);
  });
}

function copyText(btn, text) {
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = '✅ Copiado';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = '📋 Copiar respuesta'; btn.classList.remove('copied'); }, 2000);
  });
}

// ========== GAME ==========
function shuffle(arr) {
  return [...arr].sort(() => Math.random() - 0.5);
}

function startGame() {
  gameQuestions = shuffle(OBJECTIONS).slice(0, 10);
  gameIndex = 0;
  gameScore = 0;
  answered = false;
  document.getElementById('resultsScreen').classList.remove('visible');
  document.getElementById('gamePlay').style.display = 'block';
  renderQuestion();
}

function renderQuestion() {
  const q = gameQuestions[gameIndex];
  answered = false;

  document.getElementById('questionCounter').textContent = `Pregunta ${gameIndex + 1} de 10`;
  document.getElementById('scoreLabel').textContent = `Puntos: ${gameScore}`;
  document.getElementById('progressFill').style.width = `${((gameIndex + 1) / 10) * 100}%`;
  document.getElementById('questionNum').textContent = `EL CLIENTE TE DICE...`;
  document.getElementById('questionText').textContent = q.title;

  document.getElementById('feedbackBox').classList.remove('visible', 'correct-fb', 'wrong-fb');
  document.getElementById('nextBtn').classList.remove('visible');

  // Generate options: correct + 3 random wrong
  const wrong = shuffle(OBJECTIONS.filter(o => o.id !== q.id)).slice(0, 3);
  const allOptions = shuffle([q, ...wrong]);

  const grid = document.getElementById('optionsGrid');
  grid.innerHTML = '';

  allOptions.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    // Show first 80 chars of response
    const preview = opt.response.replace(/\n/g, ' ').substring(0, 100) + '...';
    btn.textContent = preview;
    btn.onclick = () => selectAnswer(btn, opt.id === q.id, q, opt);
    grid.appendChild(btn);
  });
}

function selectAnswer(btn, isCorrect, question, chosen) {
  if (answered) return;
  answered = true;

  const allBtns = document.querySelectorAll('.option-btn');
  allBtns.forEach(b => { b.disabled = true; });

  const fb = document.getElementById('feedbackBox');
  fb.classList.remove('correct-fb', 'wrong-fb');

  if (isCorrect) {
    btn.classList.add('correct');
    gameScore++;
    document.getElementById('scoreLabel').textContent = `Puntos: ${gameScore}`;
    fb.classList.add('visible', 'correct-fb');
    document.getElementById('feedbackEmoji').textContent = '🎯';
    document.getElementById('feedbackTitle').textContent = '¡Correcto! Esa es la mejor respuesta.';
    document.getElementById('feedbackText').textContent = question.response.substring(0, 180) + '...';
  } else {
    btn.classList.add('wrong');
    // Highlight correct
    const correct = question.response.replace(/\n/g, ' ').substring(0, 100) + '...';
    allBtns.forEach(b => {
      if (b.textContent.trim() === correct) b.classList.add('correct');
    });
    fb.classList.add('visible', 'wrong-fb');
    document.getElementById('feedbackEmoji').textContent = '💡';
    document.getElementById('feedbackTitle').textContent = 'No era esa. La respuesta correcta es:';
    document.getElementById('feedbackText').textContent = question.response.substring(0, 200) + '...';
  }

  document.getElementById('nextBtn').textContent = gameIndex < 9 ? 'Siguiente objeción →' : 'Ver resultados 🏆';
  document.getElementById('nextBtn').classList.add('visible');
}

function nextQuestion() {
  gameIndex++;
  if (gameIndex >= 10) {
    showResults();
  } else {
    renderQuestion();
  }
}

function showResults() {
  document.getElementById('gamePlay').style.display = 'none';
  const screen = document.getElementById('resultsScreen');
  screen.classList.add('visible');

  const pct = (gameScore / 10) * 100;
  let emoji, title, msg;

  if (pct === 100) {
    emoji = '🏆'; title = '¡Eres Top Producer!';
    msg = 'Perfecto. Conoces todas las objeciones y sabes exactamente cómo responderlas. ¡Tu equipo te necesita!';
  } else if (pct >= 80) {
    emoji = '🌟'; title = '¡Excelente Dominio!';
    msg = 'Casi perfecto. Practica las que fallaste y estarás lista para cualquier cliente.';
  } else if (pct >= 60) {
    emoji = '💪'; title = '¡Buen Progreso!';
    msg = 'Vas bien. Sigue practicando las objeciones más comunes y tu tasa de cierre va a subir.';
  } else {
    emoji = '📚'; title = 'Sigue Practicando';
    msg = 'Cada objeción que dominas es un cliente más cerrado. Revisa la Guía Completa y vuelve a intentarlo.';
  }

  document.getElementById('trophyEmoji').textContent = emoji;
  document.getElementById('resultsTitle').textContent = title;
  document.getElementById('resultsScore').textContent = `${gameScore}/10`;
  document.getElementById('resultsMessage').textContent = msg;
}

// ========== REFERENCE ==========
function buildRef() {
  const grid = document.getElementById('refGrid');
  if (grid.children.length > 0) return;

  OBJECTIONS.forEach(obj => {
    const card = document.createElement('div');
    card.className = 'ref-card';
    card.innerHTML = `
      <div class="ref-card-header" onclick="toggleRef(this.closest('.ref-card'))">
        <div>
          <div class="ref-card-title">${obj.title}</div>
          <div class="ref-card-sub">"${obj.meaning}"</div>
        </div>
        <div style="display:flex;align-items:center;gap:0.5rem">
          <span class="ref-card-num">#${obj.id}</span>
          <span class="chevron">▼</span>
        </div>
      </div>
      <div class="ref-card-body">
        <div class="ref-response">${obj.response.replace(/\n\n/g,'<br><br>').replace(/\n/g,'<br>')}</div>
      </div>
    `;
    grid.appendChild(card);
  });
}

function toggleRef(card) {
  const body = card.querySelector('.ref-card-body');
  const isOpen = body.classList.contains('open');
  document.querySelectorAll('.ref-card-body.open').forEach(b => {
    b.classList.remove('open');
    b.closest('.ref-card').classList.remove('open');
  });
  if (!isOpen) {
    body.classList.add('open');
    card.classList.add('open');
  }
}
